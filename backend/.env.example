# Docusign integration (shared across all frontends)
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_RSA_PRIVATE_KEY=your-rsa-private-key
# Required: secret key used for the one-time Docusign consent code exchange
DOCUSIGN_SECRET_KEY=your-secret-key
# Optional: separate secret for signing the stateless Docusign consent state
DOCUSIGN_STATE_SECRET=your-state-signing-secret
DOCUSIGN_OAUTH_BASE=account-d.docusign.com
DOCUSIGN_API_BASE=https://demo.docusign.net/restapi

# Server
PORT=3000
NODE_ENV=development
# Optional: override the SQLite file path, useful for mounted volumes in production
TGK_DB_PATH=backend/data/demo.db
