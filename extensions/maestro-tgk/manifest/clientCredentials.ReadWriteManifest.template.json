  "extensions": [
    {
      "name": "TGK Database Writeback",
      "description": "Read and write TGK database data from Maestro workflows.",
      "template": "DataIO.Version6.DataInputOutput",
      "actionReferences": [
        "Write to TGK database",
        "Write to TGK database (update)",
        "Read from TGK database",
        "GetTypeNames Action",
        "GetTypeDefinitions Action"
      ]
    }
  ],
  "actions": [
