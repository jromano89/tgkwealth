{
  "name": "TGK Profile Data IO",
  "description": {
    "short": "Create and update TGK profiles from Maestro",
    "long": "Private Data IO extension app for the TGK demo. It creates and updates TGK profiles in the demo backend."
  },
  "icon": {
    "data": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO9B5b8AAAAASUVORK5CYII=",
    "mediaType": "image/png"
  },
  "screenshots": [],
  "publisher": {
    "name": "__PUBLISHER_NAME__",
    "email": "__PUBLISHER_EMAIL__",
    "phone": "__PUBLISHER_PHONE__",
    "website": "__PUBLIC_BASE_URL__"
  },
  "termsOfServiceUrl": "__PUBLIC_BASE_URL__/terms",
  "privacyUrl": "__PUBLIC_BASE_URL__/privacy",
  "supportUrl": "__PUBLIC_BASE_URL__/support",
  "connections": [
    {
      "name": "tgk-authentication",
      "description": "Fake client credentials connection for the TGK Maestro demo extension",
      "type": "oauth2",
      "params": {
        "provider": "CUSTOM",
        "scopes": [],
        "grantType": "client_credentials",
        "clientId": "__CLIENT_ID__",
        "clientSecret": "__CLIENT_SECRET__",
        "customConfig": {
          "authorizationMethod": "header",
          "authorizationParams": {},
          "requiredScopes": [],
          "scopeSeparator": " ",
          "tokenUrl": "__PUBLIC_BASE_URL__/oauth/token"
        }
      }
    }
  ],
  "extensions": [
    {
      "name": "TGK Profile Writeback",
      "description": "Create and update TGK profiles from Maestro workflows.",
      "template": "DataIO.Version6.DataInputOutput",
      "actionReferences": [
        "CreateRecord Action",
        "PatchRecord Action",
        "SearchRecords Action",
        "GetTypeNames Action",
        "GetTypeDefinitions Action"
      ]
    }
  ],
  "actions": [
    {
      "name": "CreateRecord Action",
      "description": "Create a TGK profile.",
      "template": "DataIO.Version6.CreateRecord",
      "connectionsReference": "tgk-authentication",
      "params": {
        "uri": "__PUBLIC_BASE_URL__/api/dataio/createRecord"
      }
    },
    {
      "name": "PatchRecord Action",
      "description": "Update a TGK profile.",
      "template": "DataIO.Version6.PatchRecord",
      "connectionsReference": "tgk-authentication",
      "params": {
        "uri": "__PUBLIC_BASE_URL__/api/dataio/patchRecord"
      }
    },
    {
      "name": "SearchRecords Action",
      "description": "Search TGK profiles.",
      "template": "DataIO.Version6.SearchRecords",
      "connectionsReference": "tgk-authentication",
      "params": {
        "uri": "__PUBLIC_BASE_URL__/api/dataio/searchRecords"
      }
    },
    {
      "name": "GetTypeNames Action",
      "description": "List supported TGK Data IO types.",
      "template": "DataIO.Version6.GetTypeNames",
      "connectionsReference": "tgk-authentication",
      "params": {
        "uri": "__PUBLIC_BASE_URL__/api/dataio/getTypeNames"
      }
    },
    {
      "name": "GetTypeDefinitions Action",
      "description": "Return the supported TGK Data IO type definitions.",
      "template": "DataIO.Version6.GetTypeDefinitions",
      "connectionsReference": "tgk-authentication",
      "params": {
        "uri": "__PUBLIC_BASE_URL__/api/dataio/getTypeDefinitions"
      }
    }
  ],
  "publicationRegions": [
    "US"
  ],
  "distribution": "PRIVATE"
}
